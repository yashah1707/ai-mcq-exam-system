{
  "name": "ai-mcq-exam-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\" \"npm:dev:worker:email\" \"npm:dev:worker:analytics\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "dev:worker:email": "npm --prefix server run worker:email",
    "dev:worker:analytics": "npm --prefix server run worker:analytics",
    "start": "npm --prefix server run start",
    "build:client": "npm --prefix client run build",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "puppeteer": "^24.42.0"
  }
}
